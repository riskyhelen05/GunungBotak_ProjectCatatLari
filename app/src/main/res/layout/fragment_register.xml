<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="20dp"
    tools:context=".view.RegisterFragment">

    <TextView
        android:id="@+id/txt_hello_world"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create Account"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textSize="24sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <Button
        android:id="@+id/button_register"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Daftar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txt_kelas_pemrograman"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="We missed you! Login to continue to share your experience with us!"
        android:textColor="@color/biru"
        android:textAlignment="viewStart"
        android:layout_margin="10dp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/txt_hello_world"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <EditText
        android:id="@+id/et_email_signup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Masukkan email"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/et_name_signup"
        app:layout_constraintLeft_toLeftOf="@id/et_name_signup"
        app:layout_constraintRight_toRightOf="@id/et_name_signup"/>

    <EditText
        android:id="@+id/et_password_signup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Masukkan password"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/et_email_signup"
        app:layout_constraintLeft_toLeftOf="@id/et_email_signup"
        app:layout_constraintRight_toRightOf="@id/et_email_signup"/>

    <EditText
        android:id="@+id/et_retype_password_signup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Masukkan ulang password"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/et_password_signup"
        app:layout_constraintLeft_toLeftOf="@id/et_password_signup"
        app:layout_constraintRight_toRightOf="@id/et_password_signup"/>

    <EditText
        android:id="@+id/et_name_signup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Masukkan nama Anda"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/txt_kelas_pemrograman"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>