<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="20dp"
    tools:context=".view.HomeFragment">

    <TextView
        android:id="@+id/welcoming_txt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Halo, Zap!"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/ask_txt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Apa kabarmu hari ini?"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="@id/welcoming_txt"
        app:layout_constraintTop_toBottomOf="@id/welcoming_txt"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floating_btn_add_run"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/biru"
        app:srcCompat="@drawable/ic_add"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_run_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        tools:listitem="@layout/item_run"
        app:layout_constraintTop_toBottomOf="@id/ask_txt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>